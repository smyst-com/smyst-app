{
  "version": "2026-07-08",
  "policy": {
    "paidServicesAllowed": false,
    "autoBillingServicesAllowed": false,
    "productionDatabase": "salad-api-idrive-metadata",
    "centralObjectStorage": "idrive-e2",
    "designChangesRequireExplicitTask": true,
    "cssChangesRequireExplicitTask": true,
    "voiceWaveChangesRequireWrittenApproval": true,
    "apiDeleteRoutesRequireConfirmation": true,
    "githubActionsNode20WarningsAllowed": false
  },
  "protectedSurfaces": {
    "designAndCss": [
      "src/App.tsx",
      "src/lib/voiceLanguage.ts",
      "src/lib/voiceProfiles.ts",
      "src/index.css",
      "styles.css",
      "tailwind.config.ts",
      "frontend/app/globals.css",
      "frontend/components/smyst-app.tsx"
    ],
    "productionData": [
      "backend/app/main.py",
      "backend/app/api/v1/router.py",
      "backend/app/security/middleware.py",
      "backend/app/core/config.py",
      "config/backup-recovery-manifest.json"
    ],
    "api": [
      "backend/app/main.py",
      "backend/app/api/v1/router.py",
      "backend/app/api/v1/routes/asr.py",
      "backend/app/api/v1/routes/tts.py",
      "backend/app/security/middleware.py",
      "backend/app/api/v1/routes/auth.py",
      "backend/app/api/v1/routes/health.py",
      "src/lib/useTwinMvp.ts"
    ],
    "voiceWave": [
      "src/App.tsx",
      "src/lib/serverAsrClient.ts",
      "src/lib/voiceLanguage.ts",
      "src/lib/voiceProfiles.ts",
      "src/lib/useTwinMvp.ts",
      "backend/app/api/v1/routes/asr.py",
      "backend/app/api/v1/routes/tts.py",
      "voice-worker/app.py",
      "voice-worker/Dockerfile",
      "qa/voice_qa_daily.py",
      "scripts/deploy-salad-backend.mjs",
      "scripts/deploy-salad-voice-worker.mjs",
      "scripts/check-voice-wave-regression.mjs"
    ],
    "githubActions": [
      ".github/workflows/deploy.yml",
      ".github/workflows/e2e-deployment.yml",
      ".github/workflows/foundation-ci.yml",
      ".github/workflows/salad-backend-deploy.yml",
      ".github/workflows/voice-qa-daily.yml",
      ".github/workflows/voice-worker-deploy.yml"
    ]
  },
  "forbiddenProductionServices": [
    "stripe",
    "paypal",
    "supabase",
    "firebase",
    "sentry",
    "datadog",
    "posthog",
    "amplitude",
    "mixpanel",
    "vercel",
    "netlify",
    "railway",
    "render.com",
    "fly.io",
    "amazonaws",
    "azure",
    "gcp",
    "google cloud paid runtime"
  ],
  "forbiddenLegacyEdgePaidOrAutoBillingProducts": [
    "r2_buckets",
    "d1_databases",
    "durable_objects",
    "queues",
    "vectorize",
    "ai_binding",
    "analytics_engine_datasets",
    "hyperdrive",
    "browser_rendering"
  ],
  "requiredGithubActionsProtections": [
    "FORCE_JAVASCRIPT_ACTIONS_TO_NODE24",
    "actions/checkout@v6",
    "actions/setup-node@v6"
  ],
  "forbiddenGithubActionsPatterns": [
    "actions/checkout@v4",
    "actions/setup-node@v4",
    "actions/upload-artifact@v4",
    "actions/download-artifact@v4",
    "node-version: '20'",
    "node-version: \"20\"",
    "node-version: 20"
  ],
  "requiredApiProtectionTerms": [
    "CORSMiddleware",
    "RateLimitMiddleware",
    "SecurityHeadersMiddleware",
    "allow_credentials=True",
    "Strict-Transport-Security"
  ]
}
