# Smyst production runtime environment.
# Use this as the Salad backend + IDrive e2 secret/env checklist.
# Do not commit real secret values.

APP_ENV=production
APP_NAME=smyst
API_VERSION=v1

PUBLIC_BASE_URL=https://smyst.com
AUTH_PUBLIC_BASE_URL=https://smyst.com/auth
CORS_ORIGINS=https://smyst.com,https://app.smyst.com
VITE_AUTH_BASE_URL=/auth

AUTH_HMAC_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://smyst.com/auth/github/callback

SMYST_OWNER_GITHUB_IDS=
SMYST_OWNER_EMAILS=smyst247@gmail.com
SMYST_ADMIN_GITHUB_IDS=
SMYST_ADMIN_EMAILS=
SMYST_ADMIN_TOTP_SECRETS=
# Optional early single-admin fallback only. Prefer SMYST_ADMIN_TOTP_SECRETS with one secret per admin.
SMYST_ADMIN_TOTP_SECRET=

IDRIVE_E2_ENDPOINT=https://s3.us-west-2.idrivee2.com
IDRIVE_E2_BUCKET=smyst-memories
IDRIVE_E2_REGION=us-west-2
IDRIVE_E2_ACCESS_KEY=
IDRIVE_E2_SECRET_KEY=

# IDrive e2 static/PWA buckets. Public static serving requires IDrive public
# bucket access to be enabled on the account; private sync works without it.
IDRIVE_E2_SITE_BUCKET=smyst.com
IDRIVE_E2_APP_BUCKET=app.smyst.com
IDRIVE_E2_CDN_BUCKET=cdn.smyst.com
IDRIVE_E2_SET_PUBLIC_POLICY=false
IDRIVE_E2_OBJECT_ACL=

# AI provider routing. Keep secrets in GitHub Actions/Salad, never in git.
# Order is latency/cost/resilience sensitive and can be changed without code.
LLM_PROVIDER_ORDER=openrouter,openai,anthropic,gemini,xai,deepseek,moonshot,manus,mistral,groq,together,cohere,perplexity
LLM_DEFAULT_MODELS=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
MANUS_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
