# Smyst local foundation environment.
# Copy to .env for local use. Do not commit real secrets.

APP_ENV=local
APP_NAME=smyst
API_VERSION=v1
PUBLIC_BASE_URL=http://localhost:3000
AUTH_PUBLIC_BASE_URL=http://localhost:8000
VITE_AUTH_BASE_URL=/auth

AUTH_SESSION_SECRET=replace-with-48-byte-random-secret
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SMYST_OWNER_GITHUB_IDS=
SMYST_OWNER_EMAILS=
SMYST_ADMIN_GITHUB_IDS=
SMYST_ADMIN_EMAILS=

CORS_ORIGINS=http://localhost:5173
CSP_REPORT_ONLY=true
CSP_REPORT_URI=
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

IDRIVE_E2_ENDPOINT=https://s3.us-west-2.idrivee2.com
IDRIVE_E2_BUCKET=smyst-memories
IDRIVE_E2_REGION=us-west-2
IDRIVE_E2_ACCESS_KEY=
IDRIVE_E2_SECRET_KEY=
IDRIVE_E2_MAX_FILE_BYTES=52428800
IDRIVE_E2_USER_MONTHLY_BYTES=52428800
IDRIVE_E2_GLOBAL_BYTES=1073741824
IDRIVE_E2_USER_STORAGE_BYTES=104857600
IDRIVE_E2_GLOBAL_STORAGE_BYTES=1073741824
IDRIVE_E2_MAX_IMAGE_BYTES=10485760
IDRIVE_E2_MAX_VIDEO_BYTES=52428800
IDRIVE_E2_MAX_AUDIO_BYTES=26214400
IDRIVE_E2_MAX_DOCUMENT_BYTES=20971520
IDRIVE_E2_MAX_PROFILE_IMAGE_BYTES=2097152
IDRIVE_E2_MAX_BACKUP_BYTES=26214400
IDRIVE_E2_MAX_TWIN_DATA_BYTES=10485760

IDRIVE_E2_SITE_BUCKET=smyst.com
IDRIVE_E2_APP_BUCKET=app.smyst.com
IDRIVE_E2_CDN_BUCKET=cdn.smyst.com
IDRIVE_E2_SET_PUBLIC_POLICY=false
IDRIVE_E2_OBJECT_ACL=
IDRIVE_E2_PUBLIC_ACCESS_ENABLED=false
SMYST_SALAD_PUBLIC_BASE_URL=https://cherry-asparagus-a32jleuk8dgn22zu.salad.cloud

# Optional local AI provider keys. One configured provider is enough for local
# testing; production should use provider order + model overrides.
LLM_PROVIDER_ORDER=openrouter,openai,anthropic,gemini,xai,deepseek,moonshot,manus,mistral,groq,together,cohere,perplexity
LLM_DEFAULT_MODELS=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
MANUS_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
