# Salad-Runtime-Env für den smyst Backend-Container (api.smyst.com)
# Quelle: docs/runbooks/google-salad-auth.md + backend/app/core/config.py
# In der Salad-Container-Gruppe als Environment/Secrets setzen.
# Platzhalter <...> NUR du einsetzen (Secrets niemals als IDrive-Objekt ablegen).

APP_ENV=production
PUBLIC_BASE_URL=https://smyst.com
AUTH_PUBLIC_BASE_URL=https://api.smyst.com
CORS_ORIGINS=https://smyst.com,https://app.smyst.com

# --- Google OAuth (Client existiert bereits: "Smyst Web Login") ---
GOOGLE_OAUTH_CLIENT_ID=449969912847-icfrvs99eee2rlaiosij3ck5f7dcbejh.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<neues Google-Client-Secret aus der Google Cloud Console>
GOOGLE_OAUTH_REDIRECT_URI=https://api.smyst.com/auth/google/callback

# --- Session (>= 32 Byte Zufall, z. B. `openssl rand -base64 48`) ---
AUTH_SESSION_SECRET=<mind. 32 Byte Zufalls-Secret>

# --- Rollen ---
SMYST_OWNER_EMAILS=smyst247@gmail.com
SMYST_ADMIN_EMAILS=

# --- IDrive e2 (Objekt-Storage; Keys = Salad-Secret, nicht öffentlich) ---
IDRIVE_E2_ENDPOINT=https://s3.us-west-2.idrivee2.com
IDRIVE_E2_BUCKET=smyst-memories
IDRIVE_E2_REGION=us-west-2
IDRIVE_E2_ACCESS_KEY=<IDrive e2 Access Key>
IDRIVE_E2_SECRET_KEY=<IDrive e2 Secret Key>

# --- Datastores ---
# Hinweis: Für reinen Auth-Betrieb (signierte HttpOnly-Cookies) NICHT zwingend nötig.
# Für AI/RAG/Memory/Rate-Limit später echte Hosts eintragen (Postgres/Redis).
# DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>:5432/smyst
# REDIS_URL=redis://<host>:6379/0

# --- Rate Limit (Defaults aus config.py) ---
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
