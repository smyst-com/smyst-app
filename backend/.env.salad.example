# Salad-Runtime-Env für den smyst Backend-Container (api.smyst.com)
# Quelle: docs/runbooks/google-salad-auth.md + backend/app/core/config.py
# In der Salad-Container-Gruppe als Environment/Secrets setzen.
# Platzhalter <...> NUR du einsetzen (Secrets niemals als IDrive-Objekt ablegen).

APP_ENV=production
PUBLIC_BASE_URL=https://smyst.com
# HINWEIS (2026-07-04): api.smyst.com ist ausser Betrieb. SaladCloud-Gateway
# unterstuetzt keine Custom Domains (kein TLS-Zertifikat moeglich). Kanonische
# API-Basis ist die salad.cloud-URL — Produktion nutzt diese bereits (live
# verifiziert am OAuth-Redirect). Der DNS-CNAME bei Spaceship bleibt bestehen
# (harmlos), darf aber nirgends mehr referenziert werden.
AUTH_PUBLIC_BASE_URL=https://cherry-asparagus-a32jleuk8dgn22zu.salad.cloud
CORS_ORIGINS=https://smyst.com,https://app.smyst.com

# --- Google OAuth (Client existiert bereits: "Smyst Web Login") ---
GOOGLE_OAUTH_CLIENT_ID=449969912847-icfrvs99eee2rlaiosij3ck5f7dcbejh.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<neues Google-Client-Secret aus der Google Cloud Console>
GOOGLE_OAUTH_REDIRECT_URI=https://cherry-asparagus-a32jleuk8dgn22zu.salad.cloud/auth/google/callback

# --- Session (>= 32 Byte Zufall, z. B. `openssl rand -base64 48`) ---
AUTH_SESSION_SECRET=<mind. 32 Byte Zufalls-Secret>

# --- Rollen ---
SMYST_OWNER_EMAILS=smyst247@gmail.com
SMYST_ADMIN_EMAILS=

# --- IDrive e2 (Objekt-Storage; Keys = Salad-Secret, nicht öffentlich) ---
IDRIVE_E2_ENDPOINT=https://s3.us-west-2.idrivee2.com
IDRIVE_E2_BUCKET=smyst-memories
IDRIVE_E2_REGION=us-west-2
IDRIVE_E2_ACCESS_KEY=<IDrive e2 Access Key>
IDRIVE_E2_SECRET_KEY=<IDrive e2 Secret Key>

# --- Datastores ---
# Hinweis: Für reinen Auth-Betrieb (signierte HttpOnly-Cookies) NICHT zwingend nötig.
# Für AI/RAG/Memory/Rate-Limit später echte Hosts eintragen (Postgres/Redis).
# DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>:5432/smyst
# REDIS_URL=redis://<host>:6379/0

# --- Rate Limit (Defaults aus config.py) ---
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- LLM-Provider (alle Keys NUR als Salad-Secrets setzen, NIE committen) ---
# Hauptanbieter: OpenRouter (Aggregator, Position 1). Alle weiteren sind Fallback.
# Ohne gesetzte Keys läuft automatisch nur der lokale deterministische Fallback.
OPENROUTER_API_KEY=<OpenRouter Key, https://openrouter.ai/keys>
# OPENAI_API_KEY=<optional, direkter OpenAI-Zugang>
# ANTHROPIC_API_KEY=<optional, direkter Claude-Zugang>
# GEMINI_API_KEY=<optional, Google AI Studio>
# XAI_API_KEY=<optional, Grok — Ping-Check 2026-07-04: gesetzter Key UNGUELTIG (4xx); ersetzen oder Variable in Salad entfernen>
# DEEPSEEK_API_KEY=<optional — Ping-Check 2026-07-04: gesetzter Key UNGUELTIG (4xx); ersetzen oder Variable in Salad entfernen>
# MOONSHOT_API_KEY=<optional, Kimi>
# MANUS_API_KEY=<optional>
# ZHIPU_API_KEY=<optional, GLM>
# DASHSCOPE_API_KEY=<optional, Qwen>
# MISTRAL_API_KEY=<optional>
# GROQ_API_KEY=<optional>
# TOGETHER_API_KEY=<optional>
# COHERE_API_KEY=<optional>
# PERPLEXITY_API_KEY=<optional>

# Reihenfolge der Provider-Kette (erster Provider mit Key gewinnt, Rest = Fallback).
# Leer lassen = Default-Reihenfolge aus llm_router.py (openrouter zuerst).
LLM_PROVIDER_ORDER=openrouter,openai,anthropic,gemini,xai,deepseek,moonshot,manus,zhipu,dashscope,mistral,groq,together,cohere,perplexity

# Modell-Overrides pro Provider (optional), Format: provider=modell,provider=modell
# LLM_DEFAULT_MODELS=openrouter=openai/gpt-4o,gemini=gemini-2.5-flash

# Timeout pro Provider-Request (Sekunden) und Gesamt-Zeitbudget für die
# komplette Fallback-Kette. Nach Ablauf antwortet immer der lokale Fallback.
LLM_PROVIDER_TIMEOUT_SECONDS=20
LLM_TOTAL_DEADLINE_SECONDS=45

# --- Verified Web Research Layer ---
# Cache-first; Provider nur aktivieren, wenn Keys/URLs als Salad-Secrets gesetzt sind.
WEB_RESEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=disabled
BRAVE_SEARCH_API_KEY=<optional Brave Search API Key>
SEARXNG_BASE_URL=<optional private SearXNG base URL>
WEB_RESEARCH_BUDGET_PER_USER_DAY=20
WEB_RESEARCH_BUDGET_PER_PROFILE_DAY=10
